# ─────────────────────────────────────────────────
# 🔧 CRYPTO TRADING SWARM V2 — Environment Config
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────

# Database (SQLite for dev, PostgreSQL for production)
DB_URL=sqlite+aiosqlite:///./data/trading.db
# DB_URL=postgresql+asyncpg://trader:trader_secret@localhost:5432/trading
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis (required for cache, pub/sub, rate limiting)
REDIS_URL=redis://localhost:6379/0
REDIS_DECODE_RESPONSES=true
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5

# Trading Configuration
TRADE_MODE=SEMI_AUTO
TRADE_POSITION_SIZE_PCT=5.0
TRADE_MAX_DAILY_TRADES=3
TRADE_CIRCUIT_BREAKER_DAILY_LOSS_PCT=5.0
TRADE_CIRCUIT_BREAKER_CONSECUTIVE_LOSSES=3

# Scanner Configuration
SCAN_INTERVAL_SECONDS=60
SCAN_MIN_LIQUIDITY=50000
SCAN_MIN_VOLUME_24H=10000
SCAN_RATE_LIMIT_CALLS=20
SCAN_RATE_LIMIT_WINDOW=1

# Telegram
TG_BOT_TOKEN=8667434354:AAFLJ7QSSmNpyW94CdGVANzf9NuDqDJQFuc
TG_CHAT_ID=158923136

# Observability
OBS_ENABLE_PROMETHEUS=true
OBS_METRICS_PORT=9090
OBS_LOG_LEVEL=INFO
OBS_JSON_LOGS=false
# OBS_LOG_FILE=/app/logs/swarm.log
