BOT_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional: Alternative search APIs
BING_API_KEY=optional_bing_api_key
GOOGLE_CSE_ID=optional_google_cse_id
GOOGLE_API_KEY=optional_google_api_key

# Bot Settings
MAX_SEARCH_RESULTS=10
MAX_SCRAPE_CONTENT_LENGTH=50000
MEMORY_MESSAGE_LIMIT=20
REQUEST_TIMEOUT=30
RATE_LIMIT_PER_MINUTE=20

# OCR Settings
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_LANG=eng+ell

# Database
DATABASE_URL=sqlite:///./kimi_agent.db

# Logging
LOG_LEVEL=INFO
